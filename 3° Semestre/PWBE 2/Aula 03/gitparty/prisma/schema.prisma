generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Usuarios {
  id            Int          @id @default(autoincrement())
  nome          String
  email         String
  senha         String
  data_cadastro DateTime     @default(now())
  inscricoes    Inscricoes[]
}

model Eventos {
  id                Int          @id @default(autoincrement())
  titulo            String
  descricao         String
  data_evento       DateTime
  local             String
  capacidade_maxima Int
  status            StatusEvento @default(ATIVO)
  inscricoes        Inscricoes[]
}

model Inscricoes {
  id             Int             @id @default(autoincrement())
  data_inscricao DateTime        @default(now())
  status         StatusInscricao @default(CONFIRMADA)
  usuarios       Usuarios        @relation(fields: [usuariosId], references: [id])
  usuariosId     Int
  eventos        Eventos         @relation(fields: [eventosId], references: [id])
  eventosId      Int
}

enum StatusInscricao {
  CANCELADA
  CONFIRMADA
  LISTA_ESPERA
}

enum StatusEvento {
  ATIVO
  CANCELADO
  ENCERRADO
}